rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Matchmaking queue - users can create/delete their own entries
    match /matchmaking/{userId} {
      allow read, write: if true; // Open for matchmaking
      allow delete: if true; // Allow cleanup
    }
    
    // Chat rooms - only participants can access
    match /chat_rooms/{roomId} {
      allow read: if true; // Anyone can read (for now, simplify)
      allow create: if true; // Allow room creation during matchmaking
      allow update: if true; // Allow updating leftBy field
      allow delete: if true; // Allow cleanup when users disconnect
      
      // Messages within a room
      match /messages/{messageId} {
        allow read: if true; // Anyone in the room can read
        allow create: if request.resource.data.text is string &&
                         request.resource.data.text.size() > 0 &&
                         request.resource.data.text.size() <= 500; // Max 500 chars
        allow delete: if true; // Allow cleanup
      }
    }
    
    // Default deny all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
